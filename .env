
# App

APP_ENV=local
PORT=8080


# MySQL

DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=byte_shortener


# Redis

REDIS_ADDR=redis:6379


# URL Config

BASE_URL=http://localhost:8080


# Timeouts (in milliseconds)

REDIS_TIMEOUT_MS=50
DB_TIMEOUT_MS=200
HTTP_TIMEOUT_MS=500


# Logging

LOG_LEVEL=debug